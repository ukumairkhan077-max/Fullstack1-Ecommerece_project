# Copy this file to ".env" and fill in your own values.
# Never commit your real ".env" file to GitHub.

# Your MongoDB connection string.
# Local MongoDB example:
#   MONGO_URI=mongodb://127.0.0.1:27017/rabbit-store
# MongoDB Atlas (cloud) example:
#   MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/rabbit-store?retryWrites=true&w=majority
MONGO_URI=

# Port the backend server will run on
PORT=5000

# Any long, random string — used to sign/verify JWTs.
# Example: openssl rand -base64 32
JWT_SECRET=

# The URL of your deployed/local frontend (used for CORS in production).
CLIENT_URL=http://localhost:5173
